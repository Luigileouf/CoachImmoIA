# Active AI provider: `mistral` or `google`
VITE_LLM_PROVIDER=mistral

# Mistral server + UI runtime
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_MODEL=mistral-small-latest
VITE_MISTRAL_MODEL=mistral-small-latest
MISTRAL_API_BASE_URL=https://api.mistral.ai

# Google server + UI runtime
GOOGLE_API_KEY=your_google_ai_studio_api_key
GEMMA_MODEL=gemma-4-26b-a4b-it
VITE_GEMMA_MODEL=gemma-4-26b-a4b-it
GOOGLE_GENERATIVE_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Supabase server runtime
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase browser runtime
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
